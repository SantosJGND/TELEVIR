# TELE-Vir Environment Configuration
# 
# This file contains default configuration values for TELE-Vir installation.
# These values can be overridden at runtime using environment variables.

# ============================================================================
# INSTALLATION DIRECTORIES
# ============================================================================

# Data directory - where databases, metadata, and config will be stored
# Default: /opt/televir (container internal)
# For persistence, mount a volume: -v /host/path:/opt/televir
INSTALL_HOME=/opt/televir

# Environments directory
# This is where conda environments will be installed
# Typically mounted to the same volume as INSTALL_HOME
ENVDIR=/opt/televir/environments

# ============================================================================
# SOFTWARE CONFIGURATION
# ============================================================================

# Conda source script path
SOURCE=/opt/conda/etc/profile.d/conda.sh

# Taxdump location (required for NCBI taxonomy)
# Should be mounted to /opt/taxdump.tar.gz or set to custom path
TAXDUMP=/opt/taxdump.tar.gz

# ============================================================================
# INSTALLATION OPTIONS
# ============================================================================

# Update mode - set to "true" to rebuild all databases
# Use: docker run -e UPDATE=true ... televir update
UPDATE=false

# ============================================================================
# OPTIONAL: REQUEST SEQUENCES
# ============================================================================

# Path to custom request sequences file (optional)
# Can be:
#   - A path inside the container (e.g., /data/sequences.fa.gz)
#   - A path on a mounted volume
# Leave empty to skip
# REQUEST_SEQ_FILE=/data/request_sequences.fa.gz

# ============================================================================
# RUNTIME EXAMPLES
# ============================================================================
#
# Directory Structure:
#   /opt/televir-repo  - Repository code (in image, not persisted)
#   /opt/televir       - Data directory (environments, databases, configs)
#
# Example 1: Persist data to /data on host
#   docker run -v /data:/opt/televir televir move
#
# Example 2: Check installation status
#   docker run -v /data:/opt/televir televir check
#
# Example 3: Update existing installation
#   docker run -v /data:/opt/televir -e UPDATE=true televir update
#
